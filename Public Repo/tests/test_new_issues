    "l_min":       0.91563630,
    "m_max":       0.37000000,
    "r_std":       0.01215365,
    "prices_min":  0.65269710,
}

REGRESSION_CFG = SimConfig(seed=42, timesteps=200, n_agents=200, q0=0.005, alpha_r=12.0)


def _print_frozen_values():
    """Run manually to refresh FROZEN values after sim changes."""
    out = run_sim(REGRESSION_CFG)
    print(f'\n# Frozen values for sim v{SIM_VERSION}')
    print(f'"x_final":    {out.x[-1]:.8f},')
    print(f'"v_mean":     {out.v.mean():.8f},')
    print(f'"l_min":      {out.l.min():.8f},')
    print(f'"m_max":      {out.m.max():.8f},')
    print(f'"r_std":      {out.r.std():.8f},')
    print(f'"prices_min": {out.prices.min():.8f},')

def test_frozen_sim_version_matches():
    """FROZEN dict must reference the current SIM_VERSION.
    Fails explicitly when someone updates sim equations without refreshing FROZEN.
    """
    assert FROZEN["sim_version"] == SIM_VERSION, (
        f"FROZEN values were computed for sim v{FROZEN['sim_version']} "
        f"but current sim is v{SIM_VERSION}. "
        f"Run _print_frozen_values() and update FROZEN."
    )


def test_regression_frozen_values():
    """Same config + seed must reproduce identical summary stats to 7dp."""
    if any(v is None for k, v in FROZEN.items() if k != "sim_version"):
        pytest.skip("FROZEN values not yet populated — run _print_frozen_values()")

    out = run_sim(REGRESSION_CFG)
    assert out.x[-1]        == pytest.approx(FROZEN["x_final"],   abs=1e-7)
    assert out.v.mean()     == pytest.approx(FROZEN["v_mean"],     abs=1e-7)
    assert out.l.min()      == pytest.approx(FROZEN["l_min"],      abs=1e-7)
    assert out.m.max()      == pytest.approx(FROZEN["m_max"],      abs=1e-7)
    assert out.r.std()      == pytest.approx(FROZEN["r_std"],      abs=1e-7)
    assert out.prices.min() == pytest.approx(FROZEN["prices_min"], abs=1e-7)


def test_regression_different_seed_different_path():
    """A different seed must NOT match the frozen path."""
    out = run_sim(dataclasses.replace(REGRESSION_CFG, seed=99))
    if FROZEN["x_final"] is not None:
        assert out.x[-1] != pytest.approx(FROZEN["x_final"], abs=1e-4)


