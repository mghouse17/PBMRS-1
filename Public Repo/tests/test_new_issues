def test_near_critical_mt2_heuristic_in_valid_range():
    """[Issue 11-C] Basic sanity: heuristic must be in (0, 1)."""
    assert 0.0 < NEAR_CRITICAL_MT2_HEURISTIC < 1.0, (
        f"NEAR_CRITICAL_MT2_HEURISTIC={NEAR_CRITICAL_MT2_HEURISTIC} is out of (0, 1)"
    )


@pytest.mark.slow
def test_near_critical_mt2_heuristic_empirically_plausible():
    """[Issue 11-B] Empirical E[mt²] at true near-critical J should bracket the heuristic.

    J=0.83 gives J·β=0.996, very close to the critical point J·β=1.
    At this J, E[mt²] should be near the heuristic value of 0.25.
    Bracket [0.10, 0.60] is wide enough to be robust to seed variance.
    """
    cfg = SimConfig(
        timesteps=1000, n_agents=2000, q0=5e-4, J=0.83, seed=0, alpha_r=12.0
    )
    with warnings.catch_warnings():
        warnings.simplefilter('ignore')
        runs = run_ensemble(cfg, n_runs=20)

    empirical_mt2 = float(np.mean([np.mean(r.m ** 2) for r in runs]))

    assert 0.05 < empirical_mt2 < 0.60, (
        f"Empirical E[mt²]={empirical_mt2:.4f} at J=0.83 is outside [0.10, 0.60]. "
        f"NEAR_CRITICAL_MT2_HEURISTIC={NEAR_CRITICAL_MT2_HEURISTIC} may need updating."
    )
    ratio = NEAR_CRITICAL_MT2_HEURISTIC / empirical_mt2
    assert 0.1 < ratio < 10.0, (
        f"Heuristic ({NEAR_CRITICAL_MT2_HEURISTIC}) is more than 10x off from "
        f"empirical E[mt²]={empirical_mt2:.4f}."
    )


