# Issue 9 — Regime separation integration test
# ══════════════════════════════════════════════════════════════════════════════

N_RUNS_REGIME = 15    # enough to be stable, fast enough for CI
T_REGIME      = 800
# alpha_r=12.0 is required for regime separation (calibration fix v2.2)
ALPHA_R_CALIBRATED = 12.0


@pytest.fixture(scope="module")
def regime_ensembles():
    """Run three regime ensembles once and share across tests."""
    cfgs = {
        'subcrit':   SimConfig(timesteps=T_REGIME, n_agents=2000, q0=5e-4, J=0.40, seed=0, alpha_r=ALPHA_R_CALIBRATED),
        'near_crit': SimConfig(timesteps=T_REGIME, n_agents=2000, q0=5e-4, J=0.65, seed=0, alpha_r=ALPHA_R_CALIBRATED),
        'critical':  SimConfig(timesteps=T_REGIME, n_agents=2000, q0=5e-4, J=0.78, seed=0, alpha_r=ALPHA_R_CALIBRATED),
    }
    results = {}
    for name, cfg in cfgs.items():
        with warnings.catch_warnings():
            warnings.simplefilter('ignore')
            results[name] = run_ensemble(cfg, n_runs=N_RUNS_REGIME)
    return results


def test_regime_herding_increases_with_J(regime_ensembles):
    """Near-critical herding fraction should exceed subcritical."""
    def herd_frac(runs):
        return np.mean([np.mean(np.abs(r.m) > 0.3) for r in runs])

    sub  = herd_frac(regime_ensembles['subcrit'])
    near = herd_frac(regime_ensembles['near_crit'])
    crit = herd_frac(regime_ensembles['critical'])

    assert near >= sub, (
        f"Near-critical herding ({near:.4f}) should be >= subcritical ({sub:.4f})"
    )
    assert crit > sub, (
        f"Critical herding ({crit:.4f}) should exceed subcritical ({sub:.4f})"
    )


def test_regime_acf_r2_increases_with_J(regime_ensembles):
    """ACF(r^2) lag-1 (vol clustering) should increase toward criticality."""
    def acf_r2_lag1(r):
        x = r**2; s = x - x.mean(); v = float(np.dot(s, s))
        if v == 0: return 0.0
        return float(np.dot(s[:-1], s[1:])) / (v * (len(r)-1) / len(r))

    sub  = np.mean([acf_r2_lag1(r.r) for r in regime_ensembles['subcrit']])
    near = np.mean([acf_r2_lag1(r.r) for r in regime_ensembles['near_crit']])
    crit = np.mean([acf_r2_lag1(r.r) for r in regime_ensembles['critical']])

    assert near > sub, f"Vol clustering: near ({near:.4f}) should > subcrit ({sub:.4f})"
    assert crit > near, f"Vol clustering: critical ({crit:.4f}) should > near ({near:.4f})"


def test_regime_mean_abs_magnetization_increases_with_J(regime_ensembles):
    """Mean |mt| should be ordered: subcrit <= near-crit <= critical."""
    def mean_abs_m(runs):
        return np.mean([np.abs(r.m).mean() for r in runs])

    sub  = mean_abs_m(regime_ensembles['subcrit'])
    crit = mean_abs_m(regime_ensembles['critical'])

    assert crit > sub, f"E[|m|]: critical={crit:.4f} should exceed subcrit={sub:.4f}"


def test_regime_invariants_hold_for_all(regime_ensembles):
    """check_invariants must pass for every run in every regime."""
    for name, runs in regime_ensembles.items():
        for i, result in enumerate(runs):
            try:
                check_invariants(result, SimConfig())
            except ValueError as e:
                pytest.fail(f"Invariant violation in {name} run {i}: {e}")


