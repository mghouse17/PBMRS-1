# ── helpers (inline for self-containment) ─────────────────────────────────────

def max_drawdown(prices):
    peak = np.maximum.accumulate(prices)
    return float(np.max(1.0 - prices / np.where(peak == 0, 1.0, peak)))


def _kurtosis(r):
    n = len(r); mu = r.mean(); s = r.std()
    if s == 0.0: return 0.0
    return float(np.mean(((r - mu) / s) ** 4)) - 3.0


def recovery_time(prices, epsilon=0.0):
    """Returns steps from max-drawdown trough to recovery, or None if no recovery."""
    peak = np.maximum.accumulate(prices)
    dd = 1.0 - prices / np.where(peak == 0, 1.0, peak)
    t_trough = int(np.argmax(dd))
    ref_peak = float(np.max(prices[:t_trough + 1]))
    target = (1.0 - epsilon) * ref_peak
    for t in range(t_trough + 1, len(prices)):
        if prices[t] >= target:
            return t - t_trough
    return None


def recovery_time_or_inf(prices, epsilon=0.0):
    """[Issue 12] Safe wrapper: returns float('inf') when path never recovers.
    Use for arithmetic over ensembles where None would propagate silently.
    """
    result = recovery_time(prices, epsilon)
    return float('inf') if result is None else float(result)


