# Issue 12 — recovery_time() None-safety
# ══════════════════════════════════════════════════════════════════════════════

def test_recovery_time_returns_none_when_path_never_recovers():
    """A monotonically declining path should return None."""
    prices = np.array([1.0, 0.9, 0.8, 0.7, 0.6, 0.5])
    assert recovery_time(prices) is None


def test_recovery_time_returns_int_when_path_recovers():
    """A path that dips and recovers should return a positive int."""
    prices = np.array([1.0, 0.8, 0.9, 1.0, 1.1])
    result = recovery_time(prices)
    assert isinstance(result, int)
    assert result > 0


def test_recovery_time_or_inf_returns_inf_on_no_recovery():
    """[Issue 12] recovery_time_or_inf must return inf, not None."""
    prices = np.array([1.0, 0.9, 0.8, 0.7])
    result = recovery_time_or_inf(prices)
    assert result == float('inf')
    assert isinstance(result, float)


def test_recovery_time_or_inf_returns_finite_on_recovery():
    """[Issue 12] recovery_time_or_inf must return finite value on recovery."""
    prices = np.array([1.0, 0.8, 0.9, 1.0, 1.05])
    result = recovery_time_or_inf(prices)
    assert np.isfinite(result)
    assert result > 0


def test_recovery_time_or_inf_safe_in_numpy_arithmetic():
    """[Issue 12] inf-valued results must not crash np.mean or np.nanmean.

    np.mean([finite, inf]) = inf — acceptable.
    np.nanmean([finite, inf]) = inf — acceptable.
    Both are safe; neither raises TypeError (which None would).
    """
    times = [recovery_time_or_inf(np.array([1.0, 0.9, 0.8])),   # → inf
             recovery_time_or_inf(np.array([1.0, 0.8, 1.1]))]   # → finite
    result = np.mean(times)
    assert not np.isnan(result)   # inf is fine; nan is not


def test_recovery_time_or_inf_ensemble_mean_does_not_raise():
    """[Issue 12] Running recovery_time_or_inf over an ensemble shouldn't raise."""
    cfg = SimConfig(seed=0, timesteps=500, n_agents=500, q0=1e-3)
    with warnings.catch_warnings():
        warnings.simplefilter('ignore')
        runs = run_ensemble(cfg, n_runs=5)
    times = [recovery_time_or_inf(r.prices) for r in runs]
    _ = np.mean(times)   # should not raise


